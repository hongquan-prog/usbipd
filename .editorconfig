# EditorConfig: 编辑器统一配置
# 详见 https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 100
trim_trailing_whitespace = true

# C/C++ 文件
[*.{c,h,cpp,hpp}]
indent_size = 4

# Markdown 文件
[*.md]
max_line_length = 80
trim_trailing_whitespace = false

# Makefile
[Makefile]
indent_style = tab
indent_size = 8

# Python 文件
[*.py]
indent_size = 4

# Shell 脚本
[*.sh]
indent_size = 4

# JSON 文件
[*.json]
indent_size = 2

# YAML 文件
[*.{yml,yaml}]
indent_size = 2
